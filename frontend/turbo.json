{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
            "dependsOn": ["^build"]
        },
        "test": {
            "outputs": [],
            "dependsOn": []
        },
        "lint": {},
        "dev": {
            "cache": false,
            "persistent": true,
            "dependsOn": []
        },
        "tsc": {
            "dependsOn": ["^build"]
        },
        "clean": {
            "cache": false
        }
    }
}
