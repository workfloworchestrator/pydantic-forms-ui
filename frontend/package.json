{
    "private": true,
    "scripts": {
        "dev": "turbo run dev",
        "test": "turbo run test",
        "tsc": "turbo run tsc",
        "lint": "turbo run lint",
        "prettier": "prettier -c \"{**/*,*}.{ts,tsx,json,js,md}\"",
        "prettier-fix": "prettier --write \"{**/*,*}.{ts,tsx,json,js,md}\"",
        "build": "turbo run build",
        "clean": "turbo run clean && rm -rf node_modules",
        "changeset": "changeset",
        "packages:publish": "turbo run build lint test && changeset publish",
        "postinstall": "turbo run build --filter=./packages/*"
    },
    "devDependencies": {
        "@changesets/cli": "^2.30.0",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/lodash": "^4.17.24",
        "prettier": "^3.8.1",
        "turbo": "^2.8.12"
    },
    "engines": {
        "node": ">=18"
    },
    "name": "with-changesets",
    "dependencies": {
        "lodash.merge": "^4.6.2",
        "typescript": "^5.9.3"
    },
    "packageManager": "pnpm@10.28.2",
    "version": "1.0.2"
}
