{
    "name": "pydantic-forms",
    "version": "1.0.4",
    "description": "Library that turns JSONSchema into frontend forms",
    "author": {
        "name": "Workflow Orchestrator Programme",
        "email": "workfloworchestrator.board@commonsconservancy.org",
        "url": "https://www.workfloworchestrator.org"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/workfloworchestrator/pydantic-forms-ui.git"
    },
    "exports": {
        ".": {
            "types": "./src/index.tsx",
            "default": "./src/index.tsx"
        }
    },
    "publishConfig": {
        "access": "public",
        "provenance": true,
        "main": "./dist/index.js",
        "module": "./dist/index.mjs",
        "types": "./dist/index.d.ts",
        "exports": {
            ".": {
                "types": "./dist/index.d.ts",
                "import": "./dist/index.mjs",
                "require": "./dist/index.js"
            }
        }
    },
    "homepage": "https://www.workfloworchestrator.org",
    "bugs": "https://github.com/workfloworchestrator/pydantic-forms-ui/issues",
    "keywords": [
        "orchestrator",
        "workflow",
        "workflow orchestrator",
        "pydanticforms",
        "forms",
        "jsonschema"
    ],
    "browser": "./dist/index.js",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "license": "Apache-2.0",
    "files": [
        "dist/**"
    ],
    "scripts": {
        "build": "tsup src/index.tsx --format esm,cjs --dts --external react",
        "dev": "tsup src/index.tsx --format esm,cjs --watch --dts --external react",
        "lint": "eslint \"src/**/*.ts*\"",
        "tsc": "tsc --noEmit",
        "test": "jest --passWithNoTests",
        "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
    },
    "devDependencies": {
        "@jest/globals": "^29.7.0",
        "@orchestrator-ui/eslint-config-custom": "^2.2.0",
        "@orchestrator-ui/jest-config": "^1.7.0",
        "@orchestrator-ui/tsconfig": "^1.4.0",
        "@types/jest": "^29.5.14",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "eslint": "^10.0.2",
        "ts-jest": "^29.4.6",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@apidevtools/json-schema-ref-parser": "^14.2.1",
        "@emotion/react": "^11.14.0",
        "@hookform/resolvers": "^5.2.2",
        "dayjs": "^1.11.19",
        "i18next": "^24.2.3",
        "lodash": "^4.17.23",
        "next-intl": "^3.26.5",
        "react-hook-form": "^7.71.2",
        "swr": "^2.4.1",
        "zod": "^3.25.76"
    },
    "peerDependencies": {
        "next": "^14.0.0 || ^15.0.0 || ^16.0.0",
        "react": "^18.3.1 || ^19.0.0",
        "react-dom": "^18.3.1 || ^19.0.0"
    }
}
